{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./build",
    "rootDir": "./src",
    "plugins": [
      {
        "name": "typescript-plugin-resolve-plugins",
        "resolvePlugins": true
      }
    ],
    "moduleResolution": "bundler",
    "types": [
      "jest",
      "@storybook/test-runner/dist/jest-playwright-entries/runner"
    ],
  },
  "include": [
    "src/**/*",
    "../../@types",
  ]
}
